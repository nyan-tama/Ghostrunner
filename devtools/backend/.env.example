# Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (https://platform.openai.com/)
# Realtime API用のエフェメラルキー発行に使用
OPENAI_API_KEY=your-openai-api-key-here

# VOICEVOX Engine (ローカルTTS)
# VOICEVOX.app を起動すると http://localhost:50021/ でリッスン
# Swagger UI: http://localhost:50021/docs
VOICEVOX_HOST=http://localhost:50021
# speaker候補: 2=四国めたん, 3=ずんだもん, 8=春日部つむぎ, 9=雨晴はう, 10=波音リツ, 16=九州そら, 20=もち子さん
# 一覧: curl http://localhost:50021/speakers | jq '.[].styles[] | {name: .name, id: .id}'
VOICEVOX_SPEAKER_ID=8

# ntfy.sh トピック名（プッシュ通知用、オプション）
# 設定するとコマンド完了・エラー時にスマートフォンやブラウザへプッシュ通知を送信する
# 未設定の場合は通知機能が無効になる
NTFY_TOPIC=your-unique-topic-name
