# Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (https://platform.openai.com/)
# Realtime API用のエフェメラルキー発行に使用
OPENAI_API_KEY=your-openai-api-key-here

# ElevenLabs API Key (https://elevenlabs.io/)
# TTS（Text-to-Speech）の音声合成に使用。未設定の場合は /api/tts が 503 を返し、
# フロントエンドは Web Speech へフォールバックする。
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ElevenLabs デフォルト voice_id（任意、未設定時は Romaco をフォールバック使用）
ELEVENLABS_DEFAULT_VOICE_ID=KgETZ36CCLD1Cob4xpkv

# ElevenLabs デフォルトモデル（任意、未設定時は eleven_flash_v2_5 をフォールバック使用）
ELEVENLABS_DEFAULT_MODEL=eleven_flash_v2_5

# ntfy.sh トピック名（プッシュ通知用、オプション）
# 設定するとコマンド完了・エラー時にスマートフォンやブラウザへプッシュ通知を送信する
# 未設定の場合は通知機能が無効になる
NTFY_TOPIC=your-unique-topic-name
